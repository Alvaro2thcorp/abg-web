---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props as Props;
const { Content } = await post.render();

const pubDateFormatted = new Date(post.data.pubDate)
  .toLocaleDateString('es-ES', {
    day: 'numeric', month: 'long', year: 'numeric'
  });

// Artículos relacionados: misma categoría primero, luego por fecha, max 3
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p: CollectionEntry<'blog'>) => p.slug !== post.slug)
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => {
    const sameA = a.data.category === post.data.category ? 1 : 0;
    const sameB = b.data.category === post.data.category ? 1 : 0;
    if (sameB !== sameA) return sameB - sameA;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 3);
---

<Layout
  title={`${post.data.title} · ABG Blog`}
  description={post.data.description}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://abgframe.com" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://abgframe.com/blog" },
        { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `https://abgframe.com/blog/${post.slug}` }
      ]
    })} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.pubDate.toISOString(),
      "dateModified": (post.data.updatedDate || post.data.pubDate).toISOString(),
      "author": {
        "@type": "Person",
        "name": post.data.author,
        "url": "https://abgframe.com/sobre-nosotros"
      },
      "publisher": {
        "@type": "Organization",
        "name": "ABG Frame",
        "url": "https://abgframe.com"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `https://abgframe.com/blog/${post.slug}`
      }
    })} />
    {post.data.image && (
      <>
        <meta property="og:image" content={`https://abgframe.com${post.data.image}`} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="twitter:image" content={`https://abgframe.com${post.data.image}`} />
      </>
    )}
  </Fragment>

  <Navbar client:load />

  <!-- HERO DEL ARTÍCULO -->
  <header class="article-header" style="background:#080808; padding: 5rem clamp(1.5rem,5vw,5rem) 4rem; border-bottom: 1px solid rgba(242,240,237,0.06)">
    <div style="max-width:900px; margin:0 auto">

      <!-- Breadcrumb -->
      <p style="font-family:var(--font-mono); font-size:0.6rem; color:rgba(242,240,237,0.25); text-transform:uppercase; letter-spacing:0.15em; margin-bottom:3rem">
        <a href="/" style="color:inherit;text-decoration:none">ABG</a>
        {" / "} <a href="/blog" style="color:inherit;text-decoration:none">Blog</a>
        {" / "} {post.data.category}
      </p>

      {/* Portada del Artículo */}
      {post.data.image && (
        <div style="position:relative; overflow:hidden; margin-bottom:3rem; border-radius:16px; height:clamp(240px, 40vw, 400px);">
          <img 
            src={post.data.image} 
            alt={post.data.imageAlt || post.data.title} 
            style="width:100%; height:100%; object-fit:cover; object-position:center; display:block;" 
          />
          <div style="position:absolute; inset:0; background:linear-gradient(to bottom, transparent 40%, rgba(8,8,8,0.6) 100%); pointer-events:none;" />
        </div>
      )}

      <!-- Meta info -->
      <div class="article-meta" style="display:flex; gap:1rem; align-items:center; flex-wrap:wrap; margin-bottom:2rem">
        <span style="background:rgba(209,65,36,0.1); border:1px solid rgba(209,65,36,0.2); border-radius:100px; padding:0.25rem 0.75rem; font-family:var(--font-mono); font-size:0.55rem; color:#D14124; text-transform:uppercase">
          {post.data.category}
        </span>
        <span style="font-family:var(--font-mono); font-size:0.55rem; color:rgba(242,240,237,0.25); text-transform:uppercase">
          {pubDateFormatted}
        </span>
        <span style="font-family:var(--font-mono); font-size:0.55rem; color:rgba(242,240,237,0.25); text-transform:uppercase">
          {post.data.readingTime} MIN LECTURA
        </span>
      </div>

      <!-- Título -->
      <h1 style="font-family:var(--font-display); font-weight:800; font-size:clamp(2.2rem,8vw,3rem); color:#F2F0ED; line-height:1.05; letter-spacing:-0.03em; max-width:800px; margin:0;">
        {post.data.title}
      </h1>

      <!-- Descripción -->
      <p style="font-family:var(--font-body); font-weight:300; font-size:1.05rem; color:rgba(242,240,237,0.45); line-height:1.85; margin-top:1.5rem; margin-bottom:0; max-width:640px">
        {post.data.description}
      </p>

      <!-- Autor -->
      <div class="article-author" style="display:flex; align-items:center; gap:1rem; margin-top:2.5rem; padding-top:2rem; border-top:1px solid rgba(242,240,237,0.08)">
        <div style="width:36px; height:36px; border-radius:50%; background:rgba(209,65,36,0.15); border:1px solid rgba(209,65,36,0.2); display:flex; align-items:center; justify-content:center; font-family:var(--font-display); font-weight:700; font-size:0.75rem; color:#D14124">
          ÁB
        </div>
        <div>
          <span style="font-family:var(--font-display); font-weight:600; font-size:0.9rem; color:#F2F0ED; display:block">
            {post.data.author}
          </span>
          <span style="font-family:var(--font-mono); font-size:0.55rem; color:rgba(242,240,237,0.3); text-transform:uppercase">
            FUNDADOR · ABG
          </span>
        </div>
      </div>
    </div>
  </header>

  <!-- CONTENIDO DEL ARTÍCULO -->
  <article class="article-body" style="background:#F2F0ED; padding: 5rem clamp(1.5rem,5vw,5rem)">
    <div style="max-width:720px; margin:0 auto">

      <!-- Prose styles via global CSS -->
      <div class="blog-content">
        <Content />
      </div>

      <!-- Tags -->
      <div style="margin-top:4rem; padding-top:2rem; border-top:1px solid rgba(8,8,8,0.08)">
        <p style="font-family:var(--font-mono); font-size:0.55rem; color:rgba(8,8,8,0.3); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.8rem">ETIQUETAS</p>
        <div style="display:flex; flex-wrap:wrap; gap:0.5rem">
          {post.data.tags.map((tag: string) => (
            <span style="border:1px solid rgba(8,8,8,0.1); border-radius:100px; padding:0.3rem 0.8rem; font-family:var(--font-mono); font-size:0.55rem; color:rgba(8,8,8,0.4); text-transform:uppercase">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </div>
  </article>

  <!-- ARTÍCULOS RELACIONADOS -->
  {relatedPosts.length > 0 && (
    <section style="background:#F2F0ED; padding: 5rem clamp(1.5rem,5vw,5rem); border-top:1px solid rgba(8,8,8,0.06)">
      <div style="max-width:1000px; margin:0 auto">
        <p style="font-family:var(--font-mono); font-size:0.6rem; color:#D14124; text-transform:uppercase; letter-spacing:0.15em; margin-bottom:2rem">ARTÍCULOS RELACIONADOS</p>
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:1.5rem">
          {relatedPosts.map((p: CollectionEntry<'blog'>) => (
            <a href={`/blog/${p.slug}`} style="display:block; border:1px solid rgba(8,8,8,0.08); border-radius:16px; padding:1.8rem; text-decoration:none; background:#fff; transition:all 0.25s ease" onmouseover="this.style.borderColor='rgba(8,8,8,0.2)'; this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(8,8,8,0.08)'; this.style.transform='translateY(0)'">
              <span style="font-family:var(--font-mono); font-size:0.52rem; color:#D14124; text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:0.75rem">{p.data.category}</span>
              <h3 style="font-family:var(--font-display); font-weight:700; font-size:1.05rem; color:#080808; line-height:1.3; letter-spacing:-0.01em; margin:0 0 0.5rem 0">{p.data.title}</h3>
              <p style="font-family:var(--font-body); font-weight:300; font-size:0.85rem; color:rgba(8,8,8,0.45); line-height:1.6; margin:0">{p.data.description}</p>
            </a>
          ))}
        </div>

        <!-- Enlace contextual a servicios -->
        <div style="margin-top:3rem; padding:2rem; border:1px solid rgba(8,8,8,0.08); border-radius:16px; background:#080808; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1.5rem">
          <div>
            <p style="font-family:var(--font-mono); font-size:0.55rem; color:rgba(242,240,237,0.3); text-transform:uppercase; letter-spacing:0.1em; margin:0 0 0.4rem 0">¿APLICAS ESTO EN TU NEGOCIO?</p>
            <p style="font-family:var(--font-display); font-weight:700; font-size:1rem; color:#F2F0ED; margin:0; line-height:1.3">Diseño web premium. Hecho a medida.</p>
          </div>
          <div style="display:flex; gap:0.75rem; flex-wrap:wrap">
            <a href="/servicios" style="border:1px solid rgba(242,240,237,0.15); color:rgba(242,240,237,0.5); font-family:var(--font-display); font-weight:600; font-size:0.85rem; padding:0.7rem 1.4rem; border-radius:100px; text-decoration:none; white-space:nowrap; transition:all 0.3s" onmouseover="this.style.borderColor='rgba(242,240,237,0.3)'; this.style.color='#F2F0ED'" onmouseout="this.style.borderColor='rgba(242,240,237,0.15)'; this.style.color='rgba(242,240,237,0.5)'">Ver servicios →</a>
            <a href="/contacto" style="background:#D14124; color:#080808; font-family:var(--font-display); font-weight:700; font-size:0.85rem; padding:0.7rem 1.4rem; border-radius:100px; text-decoration:none; white-space:nowrap; transition:opacity 0.2s" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Análisis gratuito →</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA FINAL DEL ARTÍCULO -->
  <section style="background:#080808; padding: 5rem clamp(1.5rem,5vw,5rem); text-align:center; border-top:1px solid rgba(242,240,237,0.06)">
    <div style="max-width:600px; margin:0 auto">
      <p style="font-family:var(--font-mono); font-size:0.6rem; color:#D14124; text-transform:uppercase; letter-spacing:0.15em; margin-bottom:1.5rem">¿QUIERES APLICARLO EN TU NEGOCIO?</p>
      <h2 style="font-family:var(--font-display); font-weight:800; font-size:clamp(2rem,4vw,3.5rem); color:#F2F0ED; line-height:1.0; letter-spacing:-0.03em; margin-bottom:1.5rem; margin-top:0;">
        Análisis gratuito de tu <span class="highlight-word">situación digital.</span>
      </h2>
      <p style="font-family:var(--font-body); font-weight:300; font-size:0.95rem; color:rgba(242,240,237,0.4); line-height:1.8; margin-bottom:2.5rem; margin-top:0;">
        Sin compromiso. En 48 horas tienes un diagnóstico real
        de qué está fallando y cómo arreglarlo.
      </p>
      <a href="/contacto" style="display:inline-block; background:#D14124; color:#080808; font-family:var(--font-display); font-weight:700; font-size:0.95rem; padding:1.1rem 2.5rem; border-radius:100px; text-decoration:none; transition:all 0.3s" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(209, 65, 36, 0.35)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
        Solicitar análisis →
      </a>
      <p style="font-family:var(--font-mono); font-size:0.55rem; color:rgba(242,240,237,0.2); text-transform:uppercase; letter-spacing:0.1em; margin-top:1.5rem; margin-bottom:0;">
        SIN PERMANENCIA · RESPUESTA EN 48H
      </p>
    </div>
  </section>

</Layout>

<!-- ESTILOS GLOBALES PARA EL CONTENIDO MARKDOWN -->
<style is:global>
.blog-content {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 1rem;
  color: rgba(8,8,8,0.7);
  line-height: 1.9;
}
.blog-content h2 {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(1.6rem, 2.5vw, 2.2rem);
  color: #080808;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-top: 3rem;
  margin-bottom: 1rem;
}
.blog-content h3 {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.2rem;
  color: #080808;
  margin-top: 2rem;
  margin-bottom: 0.75rem;
}
.blog-content p {
  margin-bottom: 1.5rem;
}
.blog-content strong {
  font-weight: 700;
  color: #080808;
}
.blog-content ul {
  margin: 1.5rem 0;
  padding-left: 0;
  list-style: none;
}
.blog-content ul li {
  padding: 0.5rem 0 0.5rem 1.5rem;
  position: relative;
  border-bottom: 1px solid rgba(8,8,8,0.06);
}
.blog-content ul li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #D14124;
}
.blog-content a {
  color: #D14124;
  text-decoration: none;
  border-bottom: 1px solid rgba(209,65,36,0.3);
  transition: border-color 0.2s;
}
.blog-content a:hover {
  border-color: #D14124;
}
.blog-content blockquote {
  border-left: 3px solid #D14124;
  padding: 1rem 1.5rem;
  margin: 2rem 0;
  background: rgba(209,65,36,0.04);
  border-radius: 0 8px 8px 0;
}
.blog-content blockquote p {
  margin: 0;
  font-style: italic;
  color: rgba(8,8,8,0.6);
}

@media (max-width: 767px) {
  .article-header { padding: 4rem 1.5rem 3rem !important; }
  .article-meta { flex-direction: column !important; align-items: flex-start !important; gap: 0.8rem !important; }
  .article-author { flex-direction: column !important; align-items: flex-start !important; gap: 1.2rem !important; }
  .article-body { padding: 4rem 1.5rem !important; }
  .blog-content { max-width: 100% !important; }
}
</style>
