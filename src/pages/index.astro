---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Hero from "../components/Hero";
import HowItWorks from "../components/HowItWorks";
import WhyABG from "../components/WhyABG";
// import HomeProyectos from "../components/HomeProyectos";
import FinalCTA from "../components/FinalCTA";
import SectionTransition from "../components/SectionTransition";
import ProblemaHome from "../components/ProblemaHome";
import TechBanner from "../components/TechBanner";
---

<Layout
	title="Diseño Web Premium en Alicante | ABG Frame — Webs Que Atraen Clientes"
	description="Agencia de diseño web premium en Alicante para negocios de alto ticket. Web + SEO local + Google Ads. Solicita tu análisis gratuito sin compromiso."
>
	<Navbar client:load />

	<main>
		<Hero client:load />

		<TechBanner client:visible />

		<SectionTransition
			client:visible
			from="#080808"
			to="#F2F0ED"
			height="20vh"
		/>

		<ProblemaHome client:visible />

		<HowItWorks client:visible />

		<WhyABG client:visible />

		{/* <HomeProyectos client:load /> */}

		<FinalCTA client:visible />
	</main>
</Layout>
