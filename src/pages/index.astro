---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Hero from "../components/Hero";
import ElTimeline from "../components/ElTimeline";
import WhyABG from "../components/WhyABG";
import Resenas from "../components/Resenas";
import HomeProyectos from "../components/HomeProyectos";
import FinalCTA from "../components/FinalCTA";
import ProblemaHome from "../components/ProblemaHome";
import TechBanner from "../components/TechBanner";
---

<Layout
	title="Diseño Web Premium en Alicante | ABG Frame — Webs a Medida para Negocios Premium"
	description="Estudio de diseño web premium en San Juan de Alicante. Webs hechas a medida para negocios que no se conforman. Resultados en 4 semanas."
>
	<Navbar client:load />

	<main>
		<Hero client:load />

		<TechBanner client:visible />

		<ProblemaHome client:visible />

		<ElTimeline client:visible />

		<WhyABG client:visible />

		<HomeProyectos client:visible />

		<Resenas client:visible />

		<FinalCTA client:visible />
	</main>
</Layout>
