---
import WhatsAppButton from '../components/WhatsAppButton';

interface Props {
	title: string;
	description: string;
	ogImage?: string;
	ogType?: string;
}

const { title, description, ogImage, ogType = "website" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, "https://abgframe.com").href;
const ogImageURL = ogImage
	? `https://abgframe.com${ogImage}`
	: "https://abgframe.com/images/abglogo.png";
---

<!doctype html>
<html lang="es">
	<head>
		<!-- Charset & Viewport -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Google Tag Manager -->
		<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
		new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
		j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
		'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
		})(window,document,'script','dataLayer','GTM-PQ76T6V6');</script>
		<!-- End Google Tag Manager -->

		<!-- Primary Meta -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="ABG Frame" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalURL} />

		<!-- Favicons -->
		<link rel="icon" type="image/webp" href="/favicon.webp" />
		<link rel="shortcut icon" href="/favicon.webp" />
		<meta name="msapplication-TileImage" content="/favicon.webp" />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="ABG Frame" />
		<meta property="og:locale" content="es_ES" />

		<!-- Twitter/X Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />

		<!-- JSON-LD: Organization + LocalBusiness -->
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": ["ProfessionalService", "LocalBusiness"],
				"name": "ABG Frame",
				"url": "https://abgframe.com",
				"logo": "https://abgframe.com/images/abglogo.png",
				"image": "https://abgframe.com/images/abglogo.png",
				"description": "Agencia de diseño web premium y SEO local para negocios de alto ticket en San Juan de Alicante. Especialistas en náutica, inmobiliaria de lujo, clínicas y hoteles boutique.",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "San Juan de Alicante",
					"addressLocality": "San Juan de Alicante",
					"addressRegion": "Alicante",
					"postalCode": "03550",
					"addressCountry": "ES"
				},
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": "38.4055",
					"longitude": "-0.4271"
				},
				"telephone": "+34601058997",
				"email": "hola@abgframe.com",
				"sameAs": [
					"https://instagram.com/abgframe"
				],
				"areaServed": {
					"@type": "GeoCircle",
					"geoMidpoint": {
						"@type": "GeoCoordinates",
						"latitude": "38.4055",
						"longitude": "-0.4271"
					},
					"geoRadius": "50000"
				},
				"serviceType": [
					"Diseño Web Premium",
					"SEO Local Alicante",
					"Google Ads"
				],
				"priceRange": "€€€",
				"openingHoursSpecification": {
					"@type": "OpeningHoursSpecification",
					"dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
					"opens": "09:00",
					"closes": "18:00"
				}
			}
		</script>

		<!-- JSON-LD: WebSite with SearchAction -->
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "ABG Frame",
				"url": "https://abgframe.com",
				"potentialAction": {
					"@type": "SearchAction",
					"target": {
						"@type": "EntryPoint",
						"urlTemplate": "https://abgframe.com/blog?q={search_term_string}"
					},
					"query-input": "required name=search_term_string"
				}
			}
		</script>

		<!-- Preconnect a CDN de fuentes -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<!-- Google Fonts: DM Serif Display + Inter -->
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<slot name="head" />
	</head>

	<body>
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PQ76T6V6"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		<slot />
		<WhatsAppButton client:idle />
	</body>
</html>

<style is:global>
	@tailwind base;
	@tailwind components;
	@tailwind utilities;

	/* ── Design Tokens ── */
	:root {
		/* --- BRAND --- */
		--accent: #CC0000;          /* rojo bisturí — máx. 5% presencia */
		--isotipo: #FE6B38;         /* SOLO logo isotipo — no usar en UI */

		/* --- PALETA --- */
		--aluminum: #C8C8C8;
		--titanium: #4A4A4A;

		/* --- LIGHT SURFACE (Default) --- */
		--bg-primary: #F2F0ED;
		--surface: #F2F0ED;
		--surface2: #E8E6E3;
		--white: #080808;           /* texto en modo claro */
		--muted: #4A4A4A;           /* titanio */
		--muted2: #C8C8C8;          /* aluminio */
		--border: #E0E0E0;

		/* --- DARK SURFACE (Hero / Proyectos) --- */
		--bg-dark: #080808;
		--surface-dark: #101010;
		--text-dark-main: #F2F0ED;
		--text-dark-muted: #C8C8C8;  /* aluminio */
		--border-dark: #1A1A1A;

		--font-display: "DM Serif Display", serif;
		--font-body: "Inter", sans-serif;
		--font-mono: "Inter", sans-serif;
	}

	/* ── Reset ── */
	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	/* ── Smooth scroll ── */
	html {
		scroll-behavior: smooth;
		overflow-x: hidden;
		max-width: 100vw;
	}

	/* ── Body base ── */
	body {
		background-color: var(--bg-primary);
		color: var(--white);
		font-family: var(--font-body);
		font-size: 16px;
		line-height: 1.6;
		letter-spacing: -0.01em;
		overflow-x: hidden;
		max-width: 100vw;
	}

	section {
		max-width: 100vw;
		overflow-x: hidden;
	}

	input,
	select,
	textarea {
		font-size: 16px !important;
	}

	/* ── Custom scrollbar (Webkit) ── */
	::-webkit-scrollbar {
		width: 3px;
	}

	::-webkit-scrollbar-track {
		background: var(--bg-primary);
	}

	::-webkit-scrollbar-thumb {
		background-color: var(--accent);
		border-radius: 999px;
	}

	/* ── Custom scrollbar (Firefox) ── */
	* {
		scrollbar-width: thin;
		scrollbar-color: var(--accent) var(--bg-primary);
	}
</style>
